{
  "rules": {
    "rooms": {
      "$roomId": {
        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['uid', 'displayName', 'level', 'position', 'joinedAt']) && newData.child('uid').val() == auth.uid"
          }
        }
      }
    }
  }
}
